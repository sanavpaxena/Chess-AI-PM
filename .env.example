# Grandmaster.AI Environment Configuration
# Copy this to .env and fill in your values

# Google Gemini API Key (free tier — get from https://ai.google.dev/)
# Free: 15 requests/min, 1M tokens/day with Gemini Flash
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxx

# Gemini model to use (gemini-2.0-flash is free and fast)
GEMINI_MODEL=gemini-2.0-flash

# Path to Stockfish binary
# macOS (Homebrew): /opt/homebrew/bin/stockfish
# Linux: /usr/bin/stockfish
# Windows: C:/stockfish/stockfish.exe
STOCKFISH_PATH=/opt/homebrew/bin/stockfish

# Stockfish analysis depth (higher = more accurate, slower)
# Recommended: 16 for prototype, 20+ for production
ANALYSIS_DEPTH=16

# Maximum acceptable latency in milliseconds
MAX_LATENCY_MS=2500

# ChromaDB persistent storage path
CHROMA_DB_PATH=./data/chromadb

# Server configuration
HOST=0.0.0.0
PORT=8000
